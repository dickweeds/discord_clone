# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# JWT Secrets (generate strong random values for production)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Server Identity
SERVER_NAME=My Server

# Database
DATABASE_PATH=./data/discord_clone.db

# E2E Encryption
# Base64-encoded 32-byte group encryption key. Generated on first server start.
GROUP_ENCRYPTION_KEY=

# Logging
# LOG_LEVEL=warn  # Production default. Use 'info' or 'debug' for development only
LOG_LEVEL=info

# CORS
# CLIENT_ORIGIN=https://your-domain.com  # Restrict CORS to this origin in production
CLIENT_ORIGIN=http://localhost:5173

# mediasoup (WebRTC SFU)
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=49999

# TURN/STUN (coturn)
TURN_HOST=127.0.0.1
TURN_PORT=3478
TURN_SECRET=change-me-turn-secret

# Electron Main Process — CSP (production only)
# Used by Content-Security-Policy connect-src in the Electron main process.
# Must match the server URL the Electron app connects to.
# Not needed in development (defaults to localhost:3000).
# API_URL=https://your-domain.com
# WS_URL=wss://your-domain.com

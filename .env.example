# Server Configuration
PORT=3000
HOST=0.0.0.0
# Development: "development" | Production: "production"
NODE_ENV=development

# JWT Secrets (generate strong random values for production — scripts/setup.sh does this automatically)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Server Identity
SERVER_NAME=My Server

# Database
DATABASE_PATH=./data/discord_clone.db

# E2E Encryption
# Base64-encoded 32-byte group encryption key. Generated on first server start.
GROUP_ENCRYPTION_KEY=

# Logging
LOG_LEVEL=info

# mediasoup (WebRTC SFU)
MEDIASOUP_LISTEN_IP=0.0.0.0
# Development: 127.0.0.1 | Production: your EC2 public IP
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=49999

# TURN/STUN (coturn)
# Development: 127.0.0.1 | Production: your EC2 public IP
TURN_HOST=127.0.0.1
TURN_PORT=3478
TURN_SECRET=change-me-turn-secret

# ===== Production-Only Variables =====
# These are used by docker-compose.yml, nginx, certbot, and the landing page.
# For development, leave at defaults or blank.

# Domain name for TLS certificate and nginx (e.g., chat.example.com)
DOMAIN=your-domain.com

# Email for Let's Encrypt certificate registration
CERTBOT_EMAIL=your-email@example.com

# GitHub Releases URL for landing page download buttons
GITHUB_RELEASES_URL=https://github.com/YOUR_USER/discord-clone/releases/latest

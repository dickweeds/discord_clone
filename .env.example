# Server Configuration
PORT=3000
HOST=0.0.0.0
# Development: "development" | Production: "production"
NODE_ENV=development

# JWT Secrets (generate strong random values for production — scripts/setup.sh does this automatically)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Server Identity
SERVER_NAME=My Server

# Database — Supabase managed Postgres
# SSL required for all Supabase connections.
# Supabase connection limits: 60 direct connections on Pro tier.

# Option 1: Supavisor session mode (RECOMMENDED for most deployments)
# Routes through Supabase's connection pooler with dedicated sessions.
# Supports transactions and prepared statements.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require

# Option 2: Direct connection (bypasses Supavisor entirely)
# Use if you need maximum compatibility or are on a dedicated Supabase instance.
# Counts against the 60 direct connection limit on Pro tier.
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require

# Option 3: Supavisor transaction mode (for multiple server instances / serverless)
# Connections are pooled — each query may use a different connection.
# Requires prepare: false in postgres.js config (not currently set).
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# Connection pool settings (defaults are suitable for single-instance deployment)
# DB_POOL_MAX=10
# DB_IDLE_TIMEOUT=20
# DB_CONNECT_TIMEOUT=10

# E2E Encryption
# Base64-encoded 32-byte group encryption key. Generated on first server start.
GROUP_ENCRYPTION_KEY=

# Logging
# LOG_LEVEL=warn  # Production default. Use 'info' or 'debug' for development only
LOG_LEVEL=info

# CORS
# CLIENT_ORIGIN=https://your-domain.com  # Restrict CORS to this origin in production
CLIENT_ORIGIN=http://localhost:5173

# mediasoup (WebRTC SFU)
MEDIASOUP_LISTEN_IP=0.0.0.0
# IMPORTANT: Must be set to EC2 public IP in production.
# With bridge networking, the container IP is internal (172.x.x.x).
# mediasoup needs the public IP for WebRTC ICE candidates.
MEDIASOUP_ANNOUNCED_IP=127.0.0.1  # dev only — change for production
MEDIASOUP_MIN_PORT=40000
# Single slot — Swarm stop-first update (no blue-green split)
MEDIASOUP_MAX_PORT=40049

# TURN/STUN (coturn)
# Development: 127.0.0.1 | Production: your EC2 public IP
TURN_HOST=127.0.0.1
TURN_PORT=3478
TURN_SECRET=change-me-turn-secret

# ===== Production-Only Variables =====
# These are used by docker-compose.yml, nginx, certbot, and the landing page.
# For development, leave at defaults or blank.

# Domain name for TLS certificate and nginx (e.g., chat.example.com)
DOMAIN=your-domain.com

# Email for Let's Encrypt certificate registration
CERTBOT_EMAIL=your-email@example.com

# GitHub Releases URL for landing page download buttons
GITHUB_RELEASES_URL=https://github.com/YOUR_USER/discord-clone/releases/latest

# Docker Image Tag (set by deploy pipeline — do not change manually)
IMAGE_TAG=latest

 # Soundboard S3 Storage
SOUNDBOARD_BUCKET_NAME=your-soundboard-bucket
SOUNDBOARD_BUCKET_REGION=us-east-1

# Electron Main Process — CSP (production only)
# Used by Content-Security-Policy connect-src in the Electron main process.
# Must match the server URL the Electron app connects to.
# Not needed in development (defaults to localhost:3000).
# API_URL=https://your-domain.com
# WS_URL=wss://your-domain.com

    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "discord-clone-shared": "*",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.7.0",
    "fastify-plugin": "^5.1.0",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.0",
    "drizzle-kit": "^0.31.9",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "vitest": "^4.0.0"
  }
